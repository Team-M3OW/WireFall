# WireFall Configuration
# Copy this to .env and fill in your values

# Service
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# Redis
REDIS_URL=redis://localhost:6379

# MongoDB
MONGO_URI=mongodb://localhost:27017/waf_db
MONGO_DB=waf_db
MONGO_COLLECTION=analysis_logs

# Model paths (relative to project root)
MODEL_PATH=./model/checkpoints/distilbert_http_mlm_epoch20
SCALER_PATH=scaler.pkl
IFOREST_PATH=iforest.pkl
TRAIN_FEATURES_PATH=train_features_dvwa_fix_seed.npy

# Inference
MAX_LENGTH=256
NUM_INFERENCE_RUNS=5
MASK_PROB=0.15
Z_SCORE_THRESHOLD=7.0
